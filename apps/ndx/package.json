{
  "name": "ndx-app",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn build:webclient-front && yarn build:admin-front && yarn build:server",
    "build:front": "yarn build:webclient-front",
    "build:webclient-front": "vite build --config vite.config.ts",
    "build:admin-front": "vite build --config vite.admin.config.ts",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\" --outfile=dist/server/index.js",
    "docs:audit": "node src/webclient_front/documents/audit.mjs",
    "test": "node --import tsx --test src/server/*.test.ts src/server/agent/*.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "express": "5.2.1",
    "lucide-react": "1.14.0",
    "ndx": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "react-mentions-ts": "6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.5.0",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/express": "5.0.6",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "esbuild": "0.28.0",
    "postcss": "8.5.14",
    "supertest": "7.2.2",
    "tailwindcss": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.11"
  }
}
