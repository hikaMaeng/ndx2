{
  "name": "ndx",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "main": "./dist/common/index.js",
  "module": "./dist/common/index.js",
  "types": "./dist/common/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/common/index.d.ts",
      "import": "./dist/common/index.js"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "import": "./dist/common/index.js"
    },
    "./common/log": {
      "types": "./dist/common/log/index.d.ts",
      "import": "./dist/common/log/index.js"
    },
    "./common/responseapi": {
      "types": "./dist/common/responseapi/index.d.ts",
      "import": "./dist/common/responseapi/index.js"
    },
    "./common/protocol": {
      "types": "./dist/common/protocol/index.d.ts",
      "import": "./dist/common/protocol/index.js"
    },
    "./common/server-path": {
      "types": "./dist/common/server-path/index.d.ts",
      "import": "./dist/common/server-path/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./webclient/common": {
      "types": "./dist/webclient/common/index.d.ts",
      "import": "./dist/webclient/common/index.js"
    },
    "./webclient/common/protocol": {
      "types": "./dist/webclient/common/protocol/index.d.ts",
      "import": "./dist/webclient/common/protocol/index.js"
    },
    "./webclient/server": {
      "types": "./dist/webclient/server/index.d.ts",
      "import": "./dist/webclient/server/index.js"
    },
    "./webclient/server/client-state": {
      "types": "./dist/webclient/server/client-state/index.d.ts",
      "import": "./dist/webclient/server/client-state/index.js"
    },
    "./webclient/front": {
      "types": "./dist/webclient/front/index.d.ts",
      "import": "./dist/webclient/front/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test $(find src -name '*.test.ts' -not -path 'src/agent/init/assets/*')",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/pg": "8.15.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "pg": "8.16.3",
    "undici": "6.25.0"
  }
}
